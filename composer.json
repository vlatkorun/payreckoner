{
  "name": "payreckoner/payreckoner",
  "type": "project",
  "require": {
    "php": ">=8.4",
    "brick/money": "^0.9",
    "symfony/console": "^7.0",
    "symfony/serializer": "^7.0",
    "symfony/validator": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.10",
    "friendsofphp/php-cs-fixer": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "PayReckoner\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PayReckoner\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "analyse": "vendor/bin/phpstan analyse --level=8 --memory-limit=2G",
    "fix": "vendor/bin/php-cs-fixer fix --allow-risky=yes"
  }
}
